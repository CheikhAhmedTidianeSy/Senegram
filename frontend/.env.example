# URL du backend.
#
# LAISSE VIDE pour que le frontend detecte automatiquement l'hote courant
# (recommande en developpement : ca marche depuis localhost ET depuis
#  n'importe quelle machine du reseau local via http://<ip>:5173).
#
# Tu peux aussi forcer une URL explicite si besoin :
# VITE_API_URL=http://192.168.1.42:5000

# Port du backend, utilise uniquement si VITE_API_URL n'est pas defini.
VITE_API_PORT=5000

# (Optionnel) Serveur TURN pour WebRTC derrière NAT strict
# VITE_TURN_URL=turn:mon-turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_PASSWORD=
