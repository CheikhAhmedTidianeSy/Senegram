# Frontend Environment Variables
# Copie ce fichier vers .env.local pour le développement
# Pour la production, définis ces variables dans Vercel Dashboard > Settings > Environment Variables

# URL de l'API Backend (sans /api à la fin)
VITE_API_URL=https://senegram-backend.onrender.com/api

# URL du serveur Socket.io (même que l'API sans /api)
VITE_SOCKET_URL=https://senegram-backend.onrender.com