{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/socket.io/(.*)",
      "destination": "https://senegram-backend.onrender.com/socket.io/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://senegram-backend.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://senegram-backend.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}