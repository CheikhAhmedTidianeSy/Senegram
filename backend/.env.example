# ------- Serveur -------
PORT=5000
NODE_ENV=development

# Origines autorisees (CORS).
#   - En dev (NODE_ENV != production), TOUTES les origines sont acceptees,
#     tu peux laisser cette variable vide.
#   - En prod, mets une liste separee par virgules :
#       CLIENT_URL=https://senegram.sn,https://app.senegram.sn
CLIENT_URL=http://localhost:5173

# ------- Base de données MySQL (XAMPP par défaut) -------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=senegram

# ------- JWT -------
JWT_SECRET=remplace-moi-par-une-longue-chaine-aleatoire-senegram
JWT_EXPIRES_IN=7d

# ------- Uploads -------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800   # 50 Mo

# ------- WebRTC (optionnel : TURN) -------
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
