# Backend Environment Variables
# Copie ce fichier vers .env pour le développement local
# Pour la production, définis ces variables dans Render Dashboard > Settings > Environment Variables

# Application
NODE_ENV=production
PORT=10000

# URL du Frontend (Vercel) - IMPORTANT pour CORS
FRONTEND_URL=https://TON_APP.vercel.app

# JWT Secret (généré automatiquement sur Render avec generateValue: true)
JWT_SECRET=ton_secret_jwt_tres_long_et_aleatoire

# Base de données (injectées automatiquement par Render via fromDatabase)
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=senegram
DB_PASSWORD=xxx
DB_NAME=senegram

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=15728640

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100